config {
    type: "table",
    schema: "analytics",
    tags: ["analytics"],
    name: "dim_customers",
    description: "Customer dimension (one row per customer).",
    columns: {
        customer_id: "Customer natural key (primary key).",
        country: "Customer country; NULL if unknown.",
        signup_date: "Signup date.",
    },
}

SELECT
    customer_id,
    country,
    signup_date
FROM
    ${ref("customers_cleaned")}
